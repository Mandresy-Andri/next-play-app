# ---------- Secrets (NEVER commit) ----------
# Any file that might hold tokens, keys, or credentials
.env
.env.*
!.env.example
*.local
.mcp.json.local
secrets/
# Supabase local dev artifacts that can contain keys
.supabase/
supabase/.branches/
supabase/.temp/

# ---------- Node / Vite ----------
node_modules/
dist/
dist-ssr/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite/
.cache/

# ---------- Editors / OS ----------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------- Testing / coverage ----------
coverage/
*.lcov
.nyc_output/

# ---------- Claude Code local state (optional) ----------
# Keep agents and mcp config in git, ignore local/ephemeral state
.claude/settings.local.json
